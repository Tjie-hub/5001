async function closeTrade(id, price, reason) {
  if (!confirm(`Close trade ${reason} @ Rp ${price.toLocaleString('id-ID')}?`)) return;
  const r = await fetch('/api/paper/close', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({trade_id: id, exit_price: price, reason: reason})
  }).then(r => r.json());
  alert(`Trade closed! P&L: Rp ${r.pnl_rp?.toLocaleString('id-ID') || 0}`);
  loadPaperTrade();
}

async function closeManual(id) {
  const price = prompt('Masukkan harga exit:');
  if (!price) return;
  await closeTrade(id, parseFloat(price), 'MANUAL');
}

async function openTradeManual() {
  const ticker = document.getElementById('openTicker').value.trim().toUpperCase();
  const price  = parseFloat(document.getElementById('openPrice').value);
  if (!ticker || !price || price <= 0) {
    alert('Isi Ticker dan Harga Entry dengan benar!');
    return;
  }
  if (!confirm(`Open paper trade: ${ticker} @ Rp ${price.toLocaleString('id-ID')}?`)) return;

  const r = await fetch('/api/paper/open', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ticker: ticker, entry_price: price})
  }).then(r => r.json());

  if (r.error) {
    alert('Error: ' + r.error);
  } else {
    alert(`✅ Trade opened!\n${r.ticker} @ Rp ${r.entry_price.toLocaleString('id-ID')}\nLot: ${r.lots} | Modal: Rp ${r.capital_used.toLocaleString('id-ID')}\nTP: Rp ${r.tp_price.toLocaleString('id-ID')} | SL: Rp ${r.sl_price.toLocaleString('id-ID')}`);
    document.getElementById('openTicker').value = '';
    document.getElementById('openPrice').value  = '';
    loadPaperTrade();
  }
}

