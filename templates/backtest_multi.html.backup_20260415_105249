      <td style="padding:8px 12px; text-align:right; color:#4caf50;">${(r.buy_lot||0).toLocaleString()}</td>
      <td style="padding:8px 12px; text-align:right; color:#f44336;">${(r.sell_lot||0).toLocaleString()}</td>
      <td style="padding:8px 12px; text-align:center;">
        ${(() => {
          const ratio = r.sell_lot > 0 ? (r.buy_lot / r.sell_lot) : 99;
          const rColor = ratio >= 2 ? '#4caf50' : ratio >= 1.2 ? '#8bc34a' : ratio >= 0.8 ? '#ffc107' : ratio >= 0.5 ? '#ff9800' : '#f44336';
          const rStr = ratio >= 99 ? '∞' : ratio.toFixed(2) + 'x';
          return `<span style="color:${rColor}; font-weight:600;">${rStr}</span>`;
        })()}
      </td>
      <td style="padding:8px 12px; text-align:right; color:${netColor}; font-weight:600;">${r.net_lot >= 0 ? '+' : ''}${(r.net_lot||0).toLocaleString()}</td>
      <td style="padding:8px 12px; text-align:center; color:var(--muted); font-size:11px;">${updTime}</td>
    </tr>`;
  }).join('');
}


// ── Custom Scan ───────────────────────────────────────────
const _filterState = {
  fundamental: true, flow: true, consist: true, regime: true, streak: true
};

// Init toggle styles on load
document.addEventListener('DOMContentLoaded', () => {
  Object.keys(_filterState).forEach(k => updateToggle(k, true));
});

function updateToggle(key, init=false) {
  const label = document.getElementById('ft-' + key);
  if (!label) return;
  const cb = label.querySelector('input');
  if (!init) _filterState[key] = cb.checked;
  label.classList.toggle('active', _filterState[key]);
}

async function runCustomScan() {
  const btn = document.getElementById('customScanBtn');
  const status = document.getElementById('custom-scan-status');
  const tickers = document.getElementById('custom-tickers').value.trim();
  const vrMin = parseFloat(document.getElementById('custom-vr-min').value) || 1.3;

  btn.disabled = true;
  btn.textContent = '⏳ Scanning...';
  status.textContent = '';

  const body = {
    tickers: tickers,
    vr_min: vrMin,
    use_fundamental: _filterState.fundamental,
    use_flow: _filterState.flow,
    use_consist: _filterState.consist,
    use_regime: _filterState.regime,
    use_streak: _filterState.streak,
  };

  try {
    const res = await fetch('/api/signals/custom', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(body)
    });
    const data = await res.json();
    status.textContent = `${data.passed} lolos / ${data.total} ticker`;
    renderCustomScan(data);
  } catch(e) {
    status.textContent = 'Error: ' + e.message;
  } finally {
    btn.disabled = false;
    btn.textContent = '🔍 Run Custom Scan';
  }
}

function renderCustomScan(data) {
  const container = document.getElementById('scanAllContent');
  const results = data.results || [];
  const passed = results.filter(r => r.passed);
  const failed = results.filter(r => !r.passed);

  const regimeColor = r => r.regime === 'TRENDING' ? '#4caf50' : r.regime === 'SIDEWAYS' ? '#ffc107' : '#9e9e9e';

  let html = `
    <div style="display:flex; gap:10px; margin-bottom:14px; flex-wrap:wrap;">
      <div style="background:var(--panel);border:1px solid #2a4a2a;border-radius:8px;padding:10px 18px;text-align:center;">
        <div style="color:#4caf50;font-size:22px;font-weight:700;">${passed.length}</div>
        <div style="color:var(--muted);font-size:11px;">✅ LOLOS</div>
      </div>
      <div style="background:var(--panel);border:1px solid #4a2a2a;border-radius:8px;padding:10px 18px;text-align:center;">
        <div style="color:#f44336;font-size:22px;font-weight:700;">${failed.length}</div>
        <div style="color:var(--muted);font-size:11px;">❌ GAGAL</div>
      </div>
    </div>`;

  if (passed.length > 0) {
    html += `<div style="font-size:12px;color:#4caf50;font-weight:600;margin-bottom:8px;">✅ LOLOS SEMUA FILTER (${passed.length})</div>`;
    html += `<div class="trade-log-wrap" style="max-height:280px;overflow-y:auto;margin-bottom:16px;">
      <table><thead>
        <tr style="background:var(--panel2);font-size:12px;color:var(--muted);">
          <th style="padding:8px 12px;text-align:left;">Ticker</th>
          <th style="padding:8px 12px;text-align:right;">Close</th>
          <th style="padding:8px 12px;text-align:center;">VR</th>
          <th style="padding:8px 12px;text-align:center;">Streak</th>
          <th style="padding:8px 12px;text-align:center;">Regime</th>
          <th style="padding:8px 12px;text-align:center;">Consistency</th>
          <th style="padding:8px 12px;text-align:center;">WF Score</th>
          <th style="padding:8px 12px;text-align:left;">Flow</th>
        </tr>
      </thead><tbody>`;
    passed.forEach(r => {
      const rc = regimeColor(r);
      const vrC = r.vr >= 2 ? '#4caf50' : r.vr >= 1.3 ? '#8bc34a' : '#ffc107';
      html += `<tr style="border-bottom:1px solid var(--border);font-size:13px;">
        <td style="padding:8px 12px;font-weight:700;">${r.ticker}</td>
        <td style="padding:8px 12px;text-align:right;">Rp ${(r.close||0).toLocaleString()}</td>
        <td style="padding:8px 12px;text-align:center;color:${vrC};font-weight:600;">${r.vr}x</td>
        <td style="padding:8px 12px;text-align:center;">${r.streak ? '✅' : '❌'}</td>
        <td style="padding:8px 12px;text-align:center;color:${rc};font-size:11px;">${r.regime||'N/A'}</td>
        <td style="padding:8px 12px;text-align:center;color:var(--muted);">${r.consistency != null ? r.consistency+'%' : 'N/A'}</td>
        <td style="padding:8px 12px;text-align:center;color:var(--muted);">${r.wf_score != null ? r.wf_score.toFixed(3) : 'N/A'}</td>
        <td style="padding:8px 12px;font-size:11px;color:var(--muted);">${r.flow||'-'}</td>
      </tr>`;
    });
    html += `</tbody></table></div>`;
  }

  if (failed.length > 0) {
    html += `<div style="font-size:12px;color:#f44336;font-weight:600;margin-bottom:8px;">❌ TIDAK LOLOS (${failed.length})</div>`;
    html += `<div class="trade-log-wrap" style="max-height:220px;overflow-y:auto;">
      <table><thead>
        <tr style="background:var(--panel2);font-size:12px;color:var(--muted);">
          <th style="padding:8px 12px;text-align:left;">Ticker</th>
          <th style="padding:8px 12px;text-align:left;">Gagal di Gate</th>
          <th style="padding:8px 12px;text-align:center;">VR</th>
          <th style="padding:8px 12px;text-align:center;">Streak</th>
          <th style="padding:8px 12px;text-align:left;">Flow</th>
        </tr>
      </thead><tbody>`;
    failed.forEach(r => {
      html += `<tr style="border-bottom:1px solid var(--border);font-size:12px;opacity:0.7;">
        <td style="padding:6px 12px;font-weight:600;">${r.ticker}</td>
        <td style="padding:6px 12px;color:#f44336;">${r.fail_reason||'-'}</td>
        <td style="padding:6px 12px;text-align:center;color:var(--muted);">${r.vr != null ? r.vr+'x' : '-'}</td>
        <td style="padding:6px 12px;text-align:center;">${r.streak != null ? (r.streak ? '✅' : '❌') : '-'}</td>
        <td style="padding:6px 12px;font-size:11px;color:var(--muted);">${r.flow||'-'}</td>
      </tr>`;
    });
    html += `</tbody></table></div>`;
  }

  container.innerHTML = html;
}

</script>
</body>
</html>
