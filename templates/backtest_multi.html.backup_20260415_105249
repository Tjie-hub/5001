<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Multi-Strategy Backtest — IDX Walk-Forward</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root {
  --bg:       #0d1117;
  --panel:    #161b22;
  --border:   #30363d;
  --text:     #c9d1d9;
  --muted:    #8b949e;
  --green:    #3fb950;
  --red:      #f85149;
  --blue:     #58a6ff;
  --yellow:   #d29922;
  --purple:   #bc8cff;
  --orange:   #ffa657;
  --s1:       #58a6ff;
  --s2:       #3fb950;
  --s3:       #ffa657;
  --s4:       #bc8cff;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif; font-size: 14px; }

header {
  padding: 16px 24px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
  background: var(--panel);
}
header h1 { font-size: 18px; font-weight: 600; color: #fff; }
header .sub { color: var(--muted); font-size: 13px; }

.controls {
  display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
  margin-left: auto;
}
.controls input, .controls select {
  background: var(--bg); border: 1px solid var(--border);
  color: var(--text); padding: 6px 12px; border-radius: 6px; font-size: 13px;
}
.btn {
  background: var(--blue); color: #000; border: none;
  padding: 7px 18px; border-radius: 6px; font-size: 13px;
  font-weight: 600; cursor: pointer; transition: opacity 0.15s;
}
.btn:hover { opacity: 0.85; }
.btn.secondary { background: var(--panel); color: var(--text); border: 1px solid var(--border); }
.btn:disabled { opacity: 0.4; cursor: not-allowed; }

main { padding: 20px 24px; max-width: 1400px; margin: 0 auto; }

.tabs {
  display: flex; gap: 4px; border-bottom: 1px solid var(--border);
  margin-bottom: 20px;
}
.tab {
  padding: 9px 18px; cursor: pointer; border-radius: 6px 6px 0 0;
  color: var(--muted); font-size: 13px; font-weight: 500;
  border: 1px solid transparent; border-bottom: none;
  transition: all 0.15s;
}
.tab.active { color: #fff; background: var(--panel); border-color: var(--border); }
.tab:hover:not(.active) { color: var(--text); }

.tab-content { display: none; }
.tab-content.active { display: block; }

/* ── COMPARISON TABLE ── */
.comparison-grid {
  display: grid;
  grid-template-columns: 160px repeat(var(--num-strategies, 4), 1fr);
  border: 1px solid var(--border); border-radius: 8px; overflow: hidden;
  margin-bottom: 24px;
}
.cg-header { background: var(--panel); }
.cg-cell {
  padding: 11px 14px; border-bottom: 1px solid var(--border);
  border-right: 1px solid var(--border); font-size: 13px;
}
.cg-cell:last-child { border-right: none; }
.cg-label { color: var(--muted); font-size: 12px; }
.cg-val { font-weight: 500; }
.cg-best { color: var(--green); font-weight: 700; }
.cg-worst { color: var(--red); }
.strategy-badge {
  display: inline-block; padding: 3px 8px; border-radius: 4px;
  font-size: 11px; font-weight: 600; letter-spacing: 0.3px;
}
.s1-badge { background: rgba(88,166,255,.15); color: var(--s1); }
.s2-badge { background: rgba(63,185,80,.15);  color: var(--s2); }
.s3-badge { background: rgba(255,166,87,.15); color: var(--s3); }
.s4-badge { background: rgba(188,140,255,.15);color: var(--s4); }
:root { --s5: #f7c948; }
.s5-badge { background: rgba(247,201,72,.15); color: var(--s5); }

.winner-banner {
  background: linear-gradient(135deg, rgba(63,185,80,.12), rgba(63,185,80,.04));
  border: 1px solid rgba(63,185,80,.3);
  border-radius: 10px; padding: 16px 20px; margin-bottom: 24px;
  display: flex; align-items: center; gap: 14px;
}
.winner-banner .trophy { font-size: 28px; }
.winner-banner h2 { font-size: 16px; color: var(--green); }
.winner-banner p  { font-size: 13px; color: var(--muted); margin-top: 3px; }

/* ── CHART AREA ── */
.chart-wrap {
  background: var(--panel); border: 1px solid var(--border);
  border-radius: 8px; padding: 16px; margin-bottom: 20px;
}
.chart-wrap h3 { font-size: 13px; color: var(--muted); margin-bottom: 12px; font-weight: 500; }
.chart-wrap canvas { max-height: 320px; }

/* ── WALK-FORWARD TABLE ── */
.wf-grid {
  background: var(--panel); border: 1px solid var(--border);
  border-radius: 8px; overflow: hidden; margin-bottom: 20px;
}
.wf-grid table { width: 100%; border-collapse: collapse; }
.wf-grid th {
  background: var(--bg); padding: 10px 14px; text-align: left;
  font-size: 12px; color: var(--muted); font-weight: 500;
  border-bottom: 1px solid var(--border);
}
.wf-grid td {
  padding: 9px 14px; border-bottom: 1px solid var(--border);
  font-size: 13px;
}
.wf-grid tr:last-child td { border-bottom: none; }
.pos { color: var(--green); }
.neg { color: var(--red); }
.neu { color: var(--muted); }

/* ── TRADE LOG ── */
.trade-log-wrap { background: var(--panel); border: 1px solid var(--border); border-radius: 8px; overflow: auto; }
.trade-log-wrap table { width: 100%; border-collapse: collapse; min-width: 700px; }
.trade-log-wrap th {
  padding: 10px 12px; background: var(--bg); font-size: 12px;
  color: var(--muted); text-align: left; position: sticky; top: 0;
  border-bottom: 1px solid var(--border);
}
.trade-log-wrap td { padding: 8px 12px; font-size: 12px; border-bottom: 1px solid var(--border); }
.badge { display: inline-block; padding: 2px 7px; border-radius: 4px; font-size: 11px; font-weight: 600; }
.tp-badge  { background: rgba(63,185,80,.2);  color: var(--green); }
.sl-badge  { background: rgba(248,81,73,.2);  color: var(--red); }
.eod-badge { background: rgba(139,148,158,.2); color: var(--muted); }

.strategy-select {
  display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px;
}
.strat-btn {
  padding: 6px 14px; border-radius: 20px; font-size: 12px; cursor: pointer;
  border: 1px solid var(--border); background: var(--bg); color: var(--muted);
  transition: all 0.15s;
}
.strat-btn.active { border-color: var(--blue); color: var(--blue); background: rgba(88,166,255,.08); }

.spinner { display: inline-block; width: 16px; height: 16px; border: 2px solid var(--border); border-top-color: var(--blue); border-radius: 50%; animation: spin .7s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

.empty-state { text-align: center; padding: 60px; color: var(--muted); }
.empty-state .icon { font-size: 40px; margin-bottom: 12px; }

.metric-row { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px; margin-bottom: 20px; }
.metric-card { background: var(--panel); border: 1px solid var(--border); border-radius: 8px; padding: 14px; }
.metric-card .label { font-size: 11px; color: var(--muted); margin-bottom: 6px; }
.metric-card .value { font-size: 22px; font-weight: 700; }

.filter-toggle {
  display: flex; align-items: center; gap: 5px;
  background: var(--panel2); border: 1px solid var(--border);
  border-radius: 20px; padding: 4px 12px; font-size: 12px;
  color: var(--muted); cursor: pointer; user-select: none;
  transition: all 0.15s;
}
.filter-toggle.active {
  border-color: #4caf50; color: #4caf50; background: rgba(76,175,80,0.1);
}
.filter-toggle input { display: none; }
</style>
</head>
<body>

<header>
  <div>
    <h1>📊 Multi-Strategy Backtest</h1>
    <div class="sub" id="headerSub">IDX Walk-Forward — BBCA</div>
  </div>
  <div class="controls">
    <input type="text" id="tickerInput" value="BBCA" style="width:90px; text-transform:uppercase">
    <select id="capitalSelect">
      <option value="50000000">Rp 50 Juta</option>
      <option value="100000000">Rp 100 Juta</option>
      <option value="25000000">Rp 25 Juta</option>
    </select>
    <button class="btn" id="runBtn" onclick="runBacktest()">▶ Run Backtest</button>
    <button class="btn secondary" onclick="runWalkForward()">🔄 Walk-Forward</button>
    <button class="btn secondary" onclick="runScanAll()" id="scanBtn">🔍 Scan All</button>
  </div>
</header>
<div id="filterBar" style="background:var(--panel);border-bottom:1px solid var(--border);padding:10px 24px;display:flex;align-items:center;gap:16px;flex-wrap:wrap">
  <span style="font-size:12px;color:var(--muted);font-weight:600">FILTERS:</span>
  <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer">
    <input type="checkbox" id="f_vwma" onchange="onFilterChange()"> VWMA Above
  </label>
  <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer">
    <input type="checkbox" id="f_ma50" onchange="onFilterChange()"> MA50 Above
  </label>
  <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer">
    <input type="checkbox" id="f_atr" onchange="onFilterChange()"> Low ATR
  </label>
  <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer">
    <input type="checkbox" id="f_vr" onchange="onFilterChange()"> VR Min 1.3x
  </label>
  <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer">
    <input type="checkbox" id="f_uptrend" onchange="onFilterChange()"> Uptrend 20d
  </label>
  <span id="filterStatus" style="font-size:11px;color:var(--muted)">No filters active</span>
</div>
<div style="display:none">
  </div>
</header>

</div>
<main>
  <div class="tabs">
    <div class="tab active" onclick="switchTab('overview')">Overview</div>
    <div class="tab" onclick="switchTab('equity')">Equity Curves</div>
    <div class="tab" onclick="switchTab('walkforward')">Walk-Forward</div>
    <div class="tab" onclick="switchTab('trades')">Trade Log</div>
  <div class="tab" onclick="switchTab('scanall')">Scan All</div>
  <div class="tab" onclick="switchTab('paper')">📋 Paper Trade</div>
  <div class="tab" onclick="switchTab('flowmonitor'); loadFlowMonitor()">🌊 Flow Monitor</div>
  </div>

  <!-- OVERVIEW TAB -->
  <div id="tab-overview" class="tab-content active">
    <div id="overviewContent">
      <div class="empty-state">
        <div class="icon">📈</div>
        <div>Klik <strong>Run Backtest</strong> untuk mulai analisis 4 strategi pada BBCA</div>
      </div>
    </div>
  </div>

  <!-- EQUITY TAB -->
  <div id="tab-equity" class="tab-content">
    <div class="chart-wrap">
      <h3>Equity Curve — semua 4 strategi vs Buy & Hold</h3>
      <canvas id="equityChart"></canvas>
    </div>
  </div>

  <!-- WALK-FORWARD TAB -->
  <div id="tab-walkforward" class="tab-content">
    <div id="wfContent">
      <div class="empty-state">
        <div class="icon">🔄</div>
        <div>Klik <strong>Walk-Forward</strong> untuk analisis out-of-sample (train 12 bln / test 3 bln)</div>
      </div>
    </div>
  </div>

  <!-- TRADE LOG TAB -->
  <div id="tab-trades" class="tab-content">
    <div class="strategy-select" id="strategySelect"></div>
    <div id="tradeLogContent">
      <div class="empty-state"><div class="icon">📋</div><div>Jalankan backtest dulu</div></div>
    </div>
  </div>

  <!-- SCAN ALL TAB -->
  <div id="tab-scanall" class="tab-content">

    <!-- Custom Filter Panel -->
    <div style="background:var(--panel); border:1px solid var(--border); border-radius:8px; padding:14px 16px; margin-bottom:14px;">
      <div style="font-size:12px; color:var(--muted); margin-bottom:10px; font-weight:600; letter-spacing:0.5px;">⚙️ CUSTOM SCAN FILTERS</div>

      <!-- Ticker input -->
      <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap; margin-bottom:10px;">
        <input id="custom-tickers" type="text" placeholder="Ticker (kosong = semua, contoh: BBCA,BRPT,ESSA)"
          style="flex:1; min-width:220px; background:var(--bg); border:1px solid var(--border); color:var(--text);
                 border-radius:6px; padding:6px 10px; font-size:13px;" />
        <div style="display:flex; gap:6px; align-items:center;">
          <label style="font-size:12px; color:var(--muted);">VR Min:</label>
          <input id="custom-vr-min" type="number" value="1.3" step="0.1" min="0"
            style="width:65px; background:var(--bg); border:1px solid var(--border); color:var(--text);
                   border-radius:6px; padding:6px 8px; font-size:13px;" />
        </div>
      </div>

      <!-- Filter toggles -->
      <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:12px;">
        <label class="filter-toggle" id="ft-fundamental">
          <input type="checkbox" checked onchange="updateToggle('fundamental')"> Fundamental
        </label>
        <label class="filter-toggle" id="ft-flow">
          <input type="checkbox" checked onchange="updateToggle('flow')"> Flow
        </label>
        <label class="filter-toggle" id="ft-consist">
          <input type="checkbox" checked onchange="updateToggle('consist')"> WF Consistency
        </label>
        <label class="filter-toggle" id="ft-regime">
          <input type="checkbox" checked onchange="updateToggle('regime')"> Regime Filter
        </label>
        <label class="filter-toggle" id="ft-streak">
          <input type="checkbox" checked onchange="updateToggle('streak')"> Streak 2-hari
        </label>
      </div>

      <div style="display:flex; gap:8px; align-items:center;">
        <button class="btn" onclick="runCustomScan()" id="customScanBtn" style="padding:6px 18px;">
          🔍 Run Custom Scan
        </button>
        <button class="btn secondary" onclick="runScanAll()" id="scanBtn" style="padding:6px 18px;">
          📊 Full Backtest Scan
        </button>
        <span id="custom-scan-status" style="font-size:12px; color:var(--muted);"></span>
      </div>
    </div>

    <div id="scanAllContent">
      <div class="empty-state">
        <div class="icon">🔍</div>
        <div>Klik <strong>Run Custom Scan</strong> atau <strong>Full Backtest Scan</strong></div>
      </div>
    </div>
  </div>

  <!-- PAPER TRADE TAB -->
  <div id="tab-flowmonitor" class="tab-content">
    <div style="margin-bottom:12px; display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
      <span id="flow-date" style="color:var(--muted); font-size:13px;"></span>
      <button class="btn secondary" onclick="loadFlowMonitor()" style="padding:4px 12px; font-size:12px;">🔄 Refresh</button>
    </div>
    <div style="display:flex; gap:12px; margin-bottom:16px; flex-wrap:wrap;" id="flow-summary-cards"></div>
    <div style="display:flex; gap:8px; margin-bottom:12px;">
      <button class="btn" id="flow-btn-all"      onclick="filterFlow('all')"     style="font-size:12px; padding:4px 12px;">All</button>
      <button class="btn" id="flow-btn-bullish"  onclick="filterFlow('bullish')" style="font-size:12px; padding:4px 12px;">🟢 Bullish</button>
      <button class="btn" id="flow-btn-neutral"  onclick="filterFlow('neutral')" style="font-size:12px; padding:4px 12px;">🟡 Neutral</button>
      <button class="btn" id="flow-btn-bearish"  onclick="filterFlow('bearish')" style="font-size:12px; padding:4px 12px;">🔴 Bearish</button>
    </div>
    <div class="trade-log-wrap" style="max-height:500px; overflow-y:auto;">
      <table id="flow-table">
        <thead>
          <tr style="background:var(--panel2); font-size:12px; color:var(--muted);">
            <th style="padding:8px 12px; text-align:left;">Ticker</th>
            <th style="padding:8px 12px; text-align:center;">Score</th>
            <th style="padding:8px 12px; text-align:center;">Verdict</th>
            <th style="padding:8px 12px; text-align:center;">Smart Money</th>
            <th style="padding:8px 12px; text-align:right;">Buy Lot</th>
            <th style="padding:8px 12px; text-align:right;">Sell Lot</th>
            <th style="padding:8px 12px; text-align:center;">B/S Ratio</th>
            <th style="padding:8px 12px; text-align:right;">Net Lot</th>
            <th style="padding:8px 12px; text-align:center;">Updated</th>
          </tr>
        </thead>
        <tbody id="flow-tbody">
          <tr><td colspan="9" style="text-align:center; padding:40px; color:var(--muted);">Klik Flow Monitor untuk load data</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div id="tab-paper" class="tab-content">
    <div id="paperContent">
      <div class="empty-state"><span class="spinner"></span><div style="margin-top:12px">Loading...</div></div>
    </div>
  </div>
</main>

<script>
const COLORS = ['#58a6ff','#3fb950','#ffa657','#bc8cff','#f7c948'];
const BADGES = ['s1-badge','s2-badge','s3-badge','s4-badge','s5-badge'];
let lastResults = null;
let equityChart = null;

// ─── TAB SWITCHING ───────────────────────────
function switchTab(name) {
  document.querySelectorAll('.tab').forEach((t,i) => {
    t.classList.toggle('active', ['overview','equity','walkforward','trades','scanall','paper'][i] === name);
  });
  document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  const el = document.getElementById('tab-' + name);
  if (el) el.classList.add('active');
  if (name === 'paper') loadPaperTrade();
}

// ─── RUN BACKTEST ────────────────────────────
async function runBacktest() {
  const ticker  = document.getElementById('tickerInput').value.trim().toUpperCase();
  const capital = parseInt(document.getElementById('capitalSelect').value);
  const btn     = document.getElementById('runBtn');
  btn.disabled  = true;
  btn.innerHTML = '<span class="spinner"></span> Running...';
  document.getElementById('headerSub').textContent = `IDX Walk-Forward — ${ticker}`;
  document.getElementById('overviewContent').innerHTML = '<div class="empty-state"><span class="spinner"></span><div style="margin-top:12px">Menjalankan backtest 4 strategi...</div></div>';

  try {
    // Full backtest
    const [btRes, eqRes] = await Promise.all([
      fetch('/api/backtest/multi', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ticker, capital, filters: getActiveFilters()})
      }).then(r => r.json()),
      fetch('/api/backtest/equity', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ticker, capital, filters: getActiveFilters()})
      }).then(r => r.json())
    ]);

    if (btRes.error) { showError(btRes.error); return; }

    lastResults = btRes.results;
    renderOverview(btRes, capital);
    renderEquityChart(eqRes, ticker);
    renderStrategySelect(btRes.results);
  } catch(e) {
    showError('Gagal connect ke server: ' + e.message);
  } finally {
    btn.disabled = false;
    btn.innerHTML = '▶ Run Backtest';
  }
}

// ─── WALK-FORWARD ────────────────────────────
async function runWalkForward() {
  const ticker  = document.getElementById('tickerInput').value.trim().toUpperCase();
  const capital = parseInt(document.getElementById('capitalSelect').value);
  document.getElementById('wfContent').innerHTML = '<div class="empty-state"><span class="spinner"></span><div style="margin-top:12px">Walk-forward analysis...</div></div>';
  switchTab('walkforward');

  try {
    const data = await fetch('/api/backtest/walkforward', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ticker, capital, filters: getActiveFilters()})
    }).then(r => r.json());

    if (data.error) { document.getElementById('wfContent').innerHTML = `<div class="empty-state">${data.error}</div>`; return; }
    renderWalkForward(data);
  } catch(e) {
    document.getElementById('wfContent').innerHTML = `<div class="empty-state">Error: ${e.message}</div>`;
  }
}

// ─── RENDER OVERVIEW ─────────────────────────
function renderOverview(data, capital) {
  const results = data.results;
  // Sort by total_return_pct
  const sorted  = [...results].sort((a,b) => b.total_return_pct - a.total_return_pct);
  const best    = sorted[0];
  const stratIdx = name => results.findIndex(r => r.strategy === name);

  // Winner banner
  let html = `
  <div class="winner-banner">
    <div class="trophy">🏆</div>
    <div>
      <h2>Best Strategy: ${best.strategy}</h2>
      <p>Return ${best.total_return_pct > 0 ? '+' : ''}${best.total_return_pct}% &nbsp;·&nbsp;
         Win Rate ${best.win_rate}% &nbsp;·&nbsp;
         Sharpe ${best.sharpe} &nbsp;·&nbsp;
         ${best.total_trades} trades</p>
    </div>
  </div>`;

  // Summary metric cards for best
  html += `<div class="metric-row">`;
  const mets = [
    ['Total Return', (best.total_return_pct > 0 ? '+' : '') + best.total_return_pct + '%', best.total_return_pct >= 0 ? 'pos' : 'neg'],
    ['Win Rate',     best.win_rate + '%',         ''],
    ['Sharpe Ratio', best.sharpe,                  best.sharpe >= 1 ? 'pos' : (best.sharpe < 0 ? 'neg' : 'neu')],
    ['Profit Factor',best.profit_factor,            best.profit_factor >= 1.5 ? 'pos' : 'neg'],
    ['Max Drawdown', best.max_drawdown_pct + '%',   'neg'],
    ['Total Trades', best.total_trades,             ''],
  ];
  mets.forEach(([l,v,cls]) => {
    html += `<div class="metric-card"><div class="label">${l}</div><div class="value ${cls}">${v}</div></div>`;
  });
  html += `</div>`;

  // Comparison table
  const metrics = [
    ['Total Return (%)',    'total_return_pct',  '%',  true],
    ['Win Rate (%)',        'win_rate',           '%',  true],
    ['Avg P&L per Trade (%)', 'avg_pnl_pct',     '%',  true],
    ['Total P&L (Rp)',      'total_pnl_rp',       '',   true],
    ['Sharpe Ratio',        'sharpe',             '',   true],
    ['Profit Factor',       'profit_factor',      '',   true],
    ['Max Drawdown (%)',     'max_drawdown_pct',  '%',  false],
    ['Avg Hold (days)',      'avg_hold_days',     'd',  true],
    ['Total Trades',        'total_trades',       '',   null],
    ['Best Trade (%)',       'best_trade_pct',    '%',  true],
    ['Worst Trade (%)',      'worst_trade_pct',   '%',  false],
  ];

  const numStrat = results.length;
  document.querySelector('.comparison-grid')?.style.setProperty('--num-strategies', numStrat);
  html += `<div class="comparison-grid" style="grid-template-columns: 160px repeat(${numStrat}, 1fr)">`;
  // Header row
  html += `<div class="cg-cell cg-header cg-label">Metrik</div>`;
  results.forEach((r,i) => {
    html += `<div class="cg-cell cg-header" style="text-align:center">
      <span class="strategy-badge ${BADGES[stratIdx(r.strategy)]}">${r.strategy}</span>
    </div>`;
  });

  metrics.forEach(([label, key, suffix, higherBetter]) => {
    const vals = results.map(r => parseFloat(r[key]) || 0);
    const best_val = higherBetter === true ? Math.max(...vals) : (higherBetter === false ? Math.min(...vals) : null);

    html += `<div class="cg-cell cg-label">${label}</div>`;
    results.forEach((r, i) => {
      const v   = r[key];
      const num = parseFloat(v);
      const isBest = higherBetter !== null && num === best_val;
      const cls = isBest ? 'cg-best' : (num < 0 && key !== 'max_drawdown_pct' ? 'neg' : '');
      const display = key === 'total_pnl_rp'
        ? 'Rp ' + (num >= 0 ? '+' : '') + num.toLocaleString('id-ID')
        : (num >= 0 && (key === 'total_return_pct' || key === 'avg_pnl_pct' || key === 'best_trade_pct') ? '+' : '') + v + suffix;
      html += `<div class="cg-cell cg-val ${cls}" style="text-align:center">${display}</div>`;
    });
  });

  // Exit reasons
  html += `<div class="cg-cell cg-label">Exit: TP/SL/EOD</div>`;
  results.forEach(r => {
    const ex = r.exit_reasons || {};
    html += `<div class="cg-cell" style="text-align:center;font-size:12px">
      <span class="pos">TP:${ex.TP||0}</span> /
      <span class="neg">SL:${ex.SL||0}</span> /
      <span class="neu">EOD:${ex.EOD||0}</span>
    </div>`;
  });

  html += `</div>`;
  document.getElementById('overviewContent').innerHTML = html;
}

