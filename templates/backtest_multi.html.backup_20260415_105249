    return `<tr style="border-bottom:1px solid var(--border); font-size:13px;">
      <td style="padding:8px 12px; font-weight:600;">${r.ticker}</td>
      <td style="padding:8px 12px; text-align:center; color:${sc}; font-weight:700;">${r.score > 0 ? '+' : ''}${r.score}</td>
      <td style="padding:8px 12px; text-align:center; color:${vc};">${r.verdict}</td>
